{
  "project_name": "Baylink HKT Dashboard",
  "tech_stack": [
    "HTML5",
    "Vanilla CSS3",
    "Vanilla JS (ES6+)",
    "Chart.js"
  ],
  "design_system": {
    "theme": "Premium Dark Zinc",
    "palette": {
      "bg": "#09090b",
      "card": "#18181b",
      "border": "#27272a",
      "indigo": "#4f46e5",
      "gold_gradient": "linear-gradient(to right, #fde68a, #d97706)"
    }
  },
  "master_logic_rules": [
    "Always use Point-Based Scoring for OTP (normalized by flight volume).",
    "Enforce MIN_OTP_FLIGHTS = 3 for leaderboard eligibility.",
    "Use Average Points per Flight (avgScore) for all ranking and visual comparisons.",
    "Categorize performance: Excellence (4.5+), High (3.0-4.4), Warning (<3.0)."
  ],
  "structural_rules": [
    "Use .sections-stack for vertical layout; height: auto is mandatory.",
    "Never use fixed grid-row spans for analytical cards.",
    "Interactive popovers must use CSS-based tooltips to avoid layout disruption."
  ],
  "instructions": "Refer to MASTER_GUIDELINES.md in the root directory for full architectural details and roadmap before making structural changes."
}
